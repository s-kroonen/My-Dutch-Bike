{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/check-unity-not-running.sh",
            "shell": "bash",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/check-no-claude-coauthor.sh",
            "shell": "bash",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
